---
export const prerender = true;

import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import NewsletterForm from '@/components/NewsletterForm.astro';
import { SITE_DESCRIPTION } from '@/consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base>
  <section class="mb-12">
    <p class="text-stone-500 text-base leading-relaxed">
      {SITE_DESCRIPTION}
    </p>
  </section>

  <section>
    <h2 class="font-serif text-lg font-bold text-stone-400 uppercase tracking-widest mb-6">
      Posts
    </h2>

    {posts.length === 0 && (
      <p class="text-stone-400 italic">Nothing here yet. Check back soon.</p>
    )}

    <ul class="space-y-8">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <li>
            <a href={`/blog/${post.slug}`} class="group block">
              <article>
                <time class="text-xs text-stone-400 block mb-1" datetime={post.data.pubDate.toISOString()}>
                  {formattedDate}
                </time>
                <h3 class="font-serif text-xl font-bold text-stone-900 group-hover:text-[#c2743f] transition-colors mb-1">
                  {post.data.title}
                </h3>
                <p class="text-stone-500 text-sm leading-relaxed">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="flex gap-2 mt-2 flex-wrap">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-[#f0d9b5] text-[#8c4c1f]">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <NewsletterForm />
</Base>
